# ── Docker build context exclusions ──
# Keep the build context small and prevent leaking local state.

# Version control
.git
.gitignore

# IDE / editor
.idea
.vscode
*.iml
*.iws
*.ipr

# Build outputs (we build fresh inside the container)
target/
out/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Docs and meta (not needed for build)
docs/
examples/
scripts/
*.md
LICENSE
CHANGELOG.md
CONTRIBUTING.md

# Stray files
MyClass.java
