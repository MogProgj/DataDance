<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="structlab.gui.controller.MainWindowController"
      stylesheets="@styles.css"
      prefWidth="1400" prefHeight="850">

    <!-- ═══ App Header ═══════════════════════════════════════ -->
    <HBox styleClass="app-header" alignment="CENTER_LEFT" spacing="0">
        <HBox styleClass="brand-area" alignment="CENTER"
              minWidth="64" maxWidth="64" prefHeight="44">
            <Label text="SL" styleClass="brand-logo"/>
        </HBox>
        <Separator orientation="VERTICAL" styleClass="header-sep"/>
        <HBox alignment="CENTER_LEFT" spacing="10">
            <padding><Insets left="16" right="16"/></padding>
            <Label fx:id="pageTitleLabel" text="Explore" styleClass="page-title"/>
            <Label fx:id="pageSubtitleLabel"
                   text="Browse and simulate data structures"
                   styleClass="page-subtitle"/>
        </HBox>
        <Region HBox.hgrow="ALWAYS"/>
        <HBox alignment="CENTER_RIGHT" spacing="12">
            <padding><Insets right="20"/></padding>
            <Label fx:id="modeBadge" text="Ready" styleClass="mode-badge"/>
        </HBox>
    </HBox>

    <!-- ═══ Body: Nav Rail + Page Host ═══════════════════════ -->
    <HBox VBox.vgrow="ALWAYS">

        <!-- Navigation Rail -->
        <VBox styleClass="nav-rail" prefWidth="64" minWidth="64" maxWidth="64"
              alignment="TOP_CENTER" spacing="4">
            <padding><Insets top="12" bottom="12"/></padding>
            <Button fx:id="navExploreBtn" text="Explore" styleClass="nav-btn"
                    onAction="#onNavigate" userData="EXPLORE" mnemonicParsing="false"
                    maxWidth="Infinity"/>
            <Button fx:id="navCompareBtn" text="Compare" styleClass="nav-btn"
                    onAction="#onNavigate" userData="COMPARE" mnemonicParsing="false"
                    maxWidth="Infinity"/>
            <Button fx:id="navLearnBtn" text="Learn" styleClass="nav-btn"
                    onAction="#onNavigate" userData="LEARN" mnemonicParsing="false"
                    maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button fx:id="navActivityBtn" text="Activity" styleClass="nav-btn"
                    onAction="#onNavigate" userData="ACTIVITY" mnemonicParsing="false"
                    maxWidth="Infinity"/>
            <Button fx:id="navSettingsBtn" text="Settings" styleClass="nav-btn"
                    onAction="#onNavigate" userData="SETTINGS" mnemonicParsing="false"
                    maxWidth="Infinity"/>
        </VBox>

        <!-- Page Content Host -->
        <StackPane fx:id="pageHost" HBox.hgrow="ALWAYS" styleClass="page-host"/>

    </HBox>

    <!-- ═══ Status Bar ═══════════════════════════════════════ -->
    <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="10">
        <padding><Insets top="4" bottom="4" left="16" right="16"/></padding>
        <Label fx:id="statusLabel" text="Ready" styleClass="status-text"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="bottomStatusLabel" text="" styleClass="status-text"/>
    </HBox>

</VBox>
