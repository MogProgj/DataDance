<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="structlab.gui.controller.MainWindowController"
            stylesheets="@styles.css"
            prefWidth="1400" prefHeight="850">

    <!-- Top: App header bar -->
    <top>
        <HBox styleClass="toolbar" alignment="CENTER_LEFT" spacing="12">
            <padding><Insets top="10" bottom="10" left="20" right="20"/></padding>
            <Label text="StructLab" styleClass="app-title"/>
            <Label text="Data Structure Simulator" styleClass="status-label">
                <padding><Insets left="8"/></padding>
            </Label>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" text="Discovery Mode" styleClass="status-label"/>
        </HBox>
    </top>

    <!-- Left: Discovery panel -->
    <left>
        <VBox prefWidth="280" styleClass="side-panel" spacing="10">
            <padding><Insets top="16" bottom="16" left="14" right="14"/></padding>

            <Label text="STRUCTURES" styleClass="section-header"/>
            <ListView fx:id="structureListView" VBox.vgrow="ALWAYS"/>

            <Separator/>

            <Label text="IMPLEMENTATIONS" styleClass="section-header"/>
            <ListView fx:id="implementationListView" prefHeight="160"/>

            <VBox spacing="6">
                <Button fx:id="openSessionButton" text="Open Session"
                        onAction="#onOpenSession" maxWidth="Infinity"
                        styleClass="primary-button" disable="true"/>

                <Button fx:id="compareAllButton" text="Compare All"
                        onAction="#onCompareAll" maxWidth="Infinity"
                        styleClass="secondary-button" disable="true"/>
            </VBox>
        </VBox>
    </left>

    <!-- Center: Main workspace -->
    <center>
        <VBox styleClass="center-panel" spacing="8">
            <padding><Insets top="14" bottom="14" left="14" right="14"/></padding>

            <!-- Structure details card -->
            <TitledPane text="Structure Details" expanded="true" animated="false"
                        styleClass="section-pane">
                <VBox fx:id="structureDetailBox" spacing="6" styleClass="detail-box">
                    <padding><Insets top="10" bottom="10" left="12" right="12"/></padding>
                    <Label fx:id="detailNameLabel" text="Select a structure to view details." styleClass="detail-name"/>
                    <Label fx:id="detailCategoryLabel" text="" styleClass="info-label"/>
                    <Label fx:id="detailDescriptionLabel" text="" wrapText="true" styleClass="detail-description"/>
                    <Label fx:id="detailKeywordsLabel" text="" styleClass="detail-keywords"/>
                </VBox>
            </TitledPane>

            <!-- Structure State — main workspace area -->
            <TitledPane text="Structure State" expanded="true" animated="false"
                        styleClass="section-pane" VBox.vgrow="ALWAYS">
                <TextArea fx:id="stateArea" editable="false" wrapText="true"
                          styleClass="mono-area"
                          promptText="Open a session to see structure state here."/>
            </TitledPane>

            <!-- Trace output -->
            <TitledPane text="Trace Log" expanded="true" animated="false"
                        styleClass="section-pane">
                <TextArea fx:id="traceArea" editable="false" wrapText="true"
                          prefHeight="180" styleClass="mono-area"
                          promptText="Trace output will appear here after operations."/>
            </TitledPane>
        </VBox>
    </center>

    <!-- Right: Session inspector / operations panel -->
    <right>
        <VBox prefWidth="300" styleClass="side-panel" spacing="10">
            <padding><Insets top="16" bottom="16" left="14" right="14"/></padding>

            <!-- Session info card -->
            <Label text="SESSION" styleClass="section-header"/>
            <VBox fx:id="sessionInfoBox" spacing="4">
                <Label fx:id="sessionStructureLabel" text="No active session" styleClass="info-label"/>
                <Label fx:id="sessionImplLabel" text="" styleClass="info-label"/>
                <Label fx:id="sessionOpsCountLabel" text="" styleClass="info-label"/>
            </VBox>

            <HBox spacing="8">
                <Button fx:id="resetButton" text="Reset" onAction="#onReset"
                        styleClass="secondary-button" disable="true" HBox.hgrow="ALWAYS"
                        maxWidth="Infinity"/>
                <Button fx:id="closeSessionButton" text="Close" onAction="#onCloseSession"
                        styleClass="secondary-button" disable="true" HBox.hgrow="ALWAYS"
                        maxWidth="Infinity"/>
            </HBox>

            <Separator/>

            <!-- Operations -->
            <Label text="OPERATIONS" styleClass="section-header"/>
            <ListView fx:id="operationListView" prefHeight="150"/>

            <HBox spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="argField" promptText="select an operation"
                           onAction="#onExecuteOperation"
                           HBox.hgrow="ALWAYS"/>
                <Button fx:id="executeButton" text="Run" onAction="#onExecuteOperation"
                        styleClass="primary-button" disable="true"/>
            </HBox>

            <Separator/>

            <!-- History -->
            <Label text="HISTORY" styleClass="section-header"/>
            <ListView fx:id="historyListView" VBox.vgrow="ALWAYS"/>
        </VBox>
    </right>

    <!-- Bottom: Status bar -->
    <bottom>
        <HBox styleClass="status-bar" alignment="CENTER_LEFT" spacing="8">
            <padding><Insets top="5" bottom="5" left="16" right="16"/></padding>
            <Label fx:id="bottomStatusLabel" text="Ready" styleClass="status-text"/>
        </HBox>
    </bottom>

</BorderPane>
